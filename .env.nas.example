# StockRadar IN — NAS Environment Variables
# ==========================================
# 1. Copy this file: cp .env.nas.example .env
# 2. Fill in your real values below
# 3. NEVER commit .env to GitHub (already in .gitignore)

# ── Email Alerts (Gmail) ──────────────────────────────────────────────────────
# Go to: myaccount.google.com → Security → App Passwords → Generate
GMAIL_SENDER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
RECIPIENT_EMAIL=your@gmail.com

# ── Optional: News API (free tier: 100 req/day) ───────────────────────────────
# Get key at: newsapi.org
NEWSAPI_KEY=

# Optional: Market-data provider fallbacks.
# Used when NSE live quote endpoints block/rate-limit this machine.
# Provider order can be changed with MARKET_DATA_PROVIDER_ORDER.
ALPHA_VANTAGE_API_KEY=C0TWDRT49E1ENOT6
FINNHUB_API_KEY=d90e74hr01qk8bfl5lngd90e74hr01qk8bfl5lo0
TWELVE_DATA_API_KEY=50392ddc5cd8418ba2fc0ee5b949527a
FMP_API_KEY=s7icSMkUE9zkHGluR5bhg1KNrqjLoV7o 
MARKET_DATA_PROVIDER_ORDER=twelve_data,alpha_vantage,fmp,finnhub,groww

# ── Optional: Two-tier pipeline tuning ────────────────────────────────────────
# Tier 1 screens the full ~2,000-symbol universe with technicals only;
# Tier 2 runs deep analysis (fundamentals/news/delivery) on the top N.
DEEP_ANALYSIS_COUNT=400
# Days before a symbol's cached fundamentals are re-fetched from yfinance.
FUNDAMENTALS_CACHE_TTL_DAYS=7

# ── Optional: Telegram Alerts ─────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Get your Chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
