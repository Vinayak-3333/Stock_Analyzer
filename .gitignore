# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
.env
*.egg-info/
dist/
build/
.eggs/

# ── StockRadar secrets (NEVER commit these) ───────────────────────────────────
# No env file is tracked — real credentials live only in local .env files.
# Catch-all: matches .env, .env.nas, .env.nas.example, frontend/.env.example, …
**/.env*

# ── Database (generated at runtime) ──────────────────────────────────────────
backend/data/
*.db
*.sqlite3

# ── Node / React ──────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
output.txt

# -- graphify knowledge graph output (generated) --
graphify-out/

# -- personal work notes (local only) --
NOTES-*.md
